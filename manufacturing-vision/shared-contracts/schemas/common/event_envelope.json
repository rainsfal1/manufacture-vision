{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EventEnvelope",
  "description": "Base fields shared by all vision.events records",
  "type": "object",
  "required": [
    "schema_version",
    "event_type",
    "event_ts_ms",
    "source_id",
    "track_id",
    "zone_id",
    "confidence",
    "bbox"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "event_type":     { "type": "string" },
    "event_ts_ms":    { "type": "number" },
    "source_id":      { "type": "string" },
    "track_id":       { "type": "integer" },
    "zone_id":        { "type": "string" },
    "confidence":     { "type": "number", "minimum": 0, "maximum": 100 },
    "bbox":           { "type": "string", "description": "Stringified [x1,y1,x2,y2]" }
  }
}
