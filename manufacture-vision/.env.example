# Perception Node
SOURCE_ID=camera-01
INPUT_STREAM=data/mock_videos/ppe/clip1.mp4
FPS_LIMIT=15

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_STREAM_NAME=vision.events

# MinIO (Phase 3)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=zayyan
MINIO_SECRET_KEY=zayyan123
MINIO_BUCKET=vision-evidence
MINIO_SECURE=false

# Evidence
RING_BUFFER_RETENTION_S=30
CLIP_PRE_EVENT_S=5.0
CLIP_POST_EVENT_S=5.0
LOW_RES_WIDTH=640

# PPE
PPE_CONF_THRESH=0.4
PPE_VIOLATION_HYSTERESIS=3
PPE_VIOLATION_COOLDOWN_MS=30000

# Debug
DEBUG_OVERLAY=true

# Central Backend (Phase 4)
DATABASE_URL=postgresql://mvision:mvision@localhost:5432/mvision
JWT_SECRET=change-me-in-production
ADMIN_USER=admin
ADMIN_PASSWORD=admin
JWT_EXPIRE_HOURS=24
MEDIA_URL_EXPIRE_SECONDS=300

# PostgreSQL
POSTGRES_USER=mvision
POSTGRES_PASSWORD=mvision
POSTGRES_DB=mvision

# Phase 6 — Zone config API (perception node)
BACKEND_URL=http://localhost:8000

# Observability
LOG_FORMAT=text         # text | json
METRICS_PORT=9091       # perception-node Prometheus port

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
