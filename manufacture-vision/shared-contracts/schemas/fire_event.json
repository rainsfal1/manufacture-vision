{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FIRE_SMOKE_EVENT",
  "description": "Emitted when fire or smoke is detected in a monitored zone for N consecutive frames.",
  "allOf": [{ "$ref": "common/event_envelope.json" }],
  "properties": {
    "event_type":      { "type": "string", "enum": ["FIRE_DETECTED", "SMOKE_DETECTED"] },
    "detection_class": { "type": "string", "enum": ["fire", "smoke"] },
    "frame_confidence":{ "type": "number", "minimum": 0, "maximum": 100 }
  },
  "required": ["detection_class", "frame_confidence"]
}
